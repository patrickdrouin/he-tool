# Copy this file to .env and fill in the values before running:
#   podman compose up
#
# .env is gitignored — never commit real credentials.

# PostgreSQL credentials (used by both the db and app containers)
DB_NAME=hetool
DB_USER=hetool
DB_PASSWORD=change_me

# Flask JWT secret key — must be a long random string in production.
# Generate one with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change_me

# Gunicorn worker processes (rule of thumb: 2 * CPU cores + 1)
WORKERS=2

# Host port the app will be available on
PORT=8000
